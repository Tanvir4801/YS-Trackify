rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isAuth() && userData().role == 'super_admin';
    }

    function isInContractor(contractorId) {
      return isAuth() && userData().contractorId == contractorId;
    }

    match /contractors/{contractorId} {
      allow read: if isAuth();
      allow write: if isSuperAdmin();
    }

    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() &&
        (request.auth.uid == userId || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    match /labours/{labourId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    match /attendance/{contractorId}/dates/{date}/records/{labourId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // collectionGroup("records") query for reports
    match /{path=**}/records/{labourId} {
      allow read: if isAuth();
    }

    match /payments/{paymentId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }
  }
}
